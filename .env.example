# SpiffCo Command Center configuration
# Copy to `.env` and adjust. All backend settings use the SPIFFCO_ prefix.

# --- Application ---
SPIFFCO_APP_NAME="SpiffCo Command Center"
SPIFFCO_ENVIRONMENT=development           # development | production | test
SPIFFCO_DEBUG=true

# --- API server ---
SPIFFCO_HOST=127.0.0.1
SPIFFCO_PORT=8000
# Comma-separated list of allowed CORS origins (frontend dev server by default)
SPIFFCO_CORS_ORIGINS=http://localhost:5173

# --- Database ---
# SQLite by default; switch to PostgreSQL later, e.g.:
#   postgresql+asyncpg://user:pass@localhost:5432/spiffco
SPIFFCO_DATABASE_URL=sqlite+aiosqlite:///./spiffco.db

# --- Logging ---
SPIFFCO_LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
SPIFFCO_LOG_FILE=                         # e.g. logs/spiffco.log (empty = console only)

# --- Background scheduler ---
SPIFFCO_SCHEDULER_ENABLED=true            # periodic refresh/history jobs (off in tests)

# --- Ficsit Remote Monitoring (Phase 11) ---
# When enabled, the app polls the FRM mod for live data and falls back to the
# simulated providers if it is unreachable at startup.
SPIFFCO_FRM_ENABLED=false
SPIFFCO_FRM_BASE_URL=http://localhost:8080
SPIFFCO_FRM_POLL_INTERVAL_SECONDS=5.0
SPIFFCO_FRM_TIMEOUT_SECONDS=5.0
SPIFFCO_FRM_CACHE_TTL_SECONDS=2.0

# --- Offline Mode (Phase 12): save-file upload ---
SPIFFCO_SAVE_MAX_UPLOAD_MB=100            # reject .sav uploads larger than this

# --- Single-origin deploy (optional) ---
# Path to a built frontend (Vite dist/). When set, the API also serves the SPA
# from the same origin (see the Fly.io deploy). Leave empty in dev.
SPIFFCO_STATIC_DIR=

# --- Optional authentication (disabled by default) ---
SPIFFCO_AUTH_ENABLED=false
SPIFFCO_AUTH_TOKEN=                       # static bearer token when auth is enabled
